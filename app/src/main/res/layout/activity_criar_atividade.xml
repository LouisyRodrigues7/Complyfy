<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Título da Atividade -->
    <EditText
        android:id="@+id/editTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Título da Atividade"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Descrição da Atividade -->
    <EditText
        android:id="@+id/editDescricao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Descrição"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:gravity="top"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/editTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Spinner para Seleção da Ação -->
    <Spinner
        android:id="@+id/spinnerAcao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/editDescricao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- EditText para Data de Início -->
    <EditText
        android:id="@+id/editDataInicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Data de Início"
        android:inputType="none"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/spinnerAcao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- EditText para Data de Conclusão -->
    <EditText
        android:id="@+id/editDataConclusao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Data de Conclusão"
        android:focusable="false"
        android:clickable="true"
        android:inputType="none"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/editDataInicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botão para Salvar -->
    <Button
        android:id="@+id/btnSalvar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Salvar"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/editDataConclusao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


